---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navItems = [
  { href: '/#booking', label: 'Book Now' },
  { href: '/#features', label: 'Features' },
  { href: '/#gallery', label: 'Gallery' },
  { href: '/#about-us', label: 'About Us' },
  { href: '/#contact', label: 'Contact' },
];
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent ? 'bg-transparent text-primary' : 'bg-background/90 backdrop-blur-sm text-primary',
  ]}
  data-header
  data-transparent={transparent.toString()}
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex items-center justify-between">
    <a href="/" class="hover:opacity-80 transition-opacity" aria-label="Home">
        <img
        src="/cmf/Logo-Maria-Flora-transparent.png"
        alt="Casa Maria Flora"
        class="w-[170px] md:w-[220px] h-16 md:h-18 object-cover [object-position:center_46%] block"
      />
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm tracking-[0.18em] uppercase transition-opacity opacity-80 hover:opacity-100"
          >
            {label}
          </a>
        </li>
      ))}
      <li class="ml-4">
        <a
          href="/#booking"
          class="inline-flex items-center rounded-full border border-current/30 bg-background/25 px-4 py-2 text-xs tracking-[0.18em] uppercase hover:bg-background/40"
        >
          Book Now
        </a>
      </li>
    </ul>

    <button class="md:hidden p-2 -mr-2" aria-label="Toggle menu" data-menu-toggle>
      <div class="w-6 flex flex-col gap-1.5" data-menu-icon>
        <span class="block h-px bg-current transition-transform origin-center"></span>
        <span class="block h-px bg-current transition-opacity"></span>
        <span class="block h-px bg-current transition-transform origin-center"></span>
      </div>
    </button>
  </nav>

  <div
    class="md:hidden fixed inset-0 bg-background text-primary z-40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
    data-mobile-menu
  >
    <div class="flex flex-col items-center gap-12">
      <ul class="flex flex-col items-center gap-8">
        {navItems.map(({ href, label }) => (
          <li>
            <a href={href} class="text-2xl font-serif tracking-wide">
              {label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href="/#booking"
        class="inline-flex items-center rounded-full border border-primary/20 px-5 py-3 text-sm tracking-[0.16em] uppercase"
      >
        Book Now
      </a>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.querySelector('[data-header]') as HTMLElement;
    const menuToggle = document.querySelector('[data-menu-toggle]') as HTMLButtonElement;
    const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLElement;
    const menuIcon = document.querySelector('[data-menu-icon]') as HTMLElement;

    if (!header || !menuToggle || !mobileMenu || !menuIcon) return;

    let isMenuOpen = false;

    menuToggle.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        menuIcon.classList.add('menu-open');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        menuIcon.classList.remove('menu-open');
        document.body.style.overflow = '';
      }
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        menuIcon.classList.remove('menu-open');
        document.body.style.overflow = '';
        isMenuOpen = false;
      });
    });

    window.addEventListener(
      'scroll',
      () => {
        const currentScroll = window.scrollY;

        if (currentScroll > 100) {
          header.classList.remove('bg-transparent');
          header.classList.add('bg-background/90', 'backdrop-blur-sm', 'text-primary');
        } else if (header.dataset.transparent === 'true') {
          header.classList.add('bg-transparent', 'text-primary');
          header.classList.remove('bg-background/90', 'backdrop-blur-sm');
        }
      },
      { passive: true }
    );
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
  [data-menu-icon].menu-open span:first-child {
    transform: translateY(5px) rotate(45deg);
  }

  [data-menu-icon].menu-open span:nth-child(2) {
    opacity: 0;
  }

  [data-menu-icon].menu-open span:last-child {
    transform: translateY(-5px) rotate(-45deg);
  }
</style>
