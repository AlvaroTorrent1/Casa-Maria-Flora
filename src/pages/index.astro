---
export const prerender = true;

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FadeIn from '../components/FadeIn.astro';
import AmenityIcon from '../components/AmenityIcon.astro';
import { getCmfCopy } from '../i18n/cmf';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const heroImage = '/cmf/1.3.png';
const imgBedroom = '/cmf/Foto-Gallary-7.jpg';
const imgKitchen = '/cmf/PHOTO-2023-06-08-12-01-40-3.jpg';
const imgLiving = '/cmf/PHOTO-2023-06-08-12-01-40-7.jpg';
const imgDining = '/cmf/PHOTO-2023-06-08-12-02-45-3.jpg';
const imgTerrace = '/cmf/PHOTO-2023-06-08-12-01-40.jpg';
const imgLaundry = '/cmf/PHOTO-2023-06-08-12-01-40-6-1.jpg';
const imgFacade = '/cmf/facade.png';
const imgSisters = '/cmf/PHOTO-2022-10-28-10-05-44.jpg';
const imgOjen = '/cmf/OjenSpain-scaled.jpeg';
const imgPlaza = '/cmf/plaza-ojen.jpeg';
const imgBeach = '/cmf/istockphoto-1363636426-612x612-1.jpeg';
const imgDormitorio = '/dormitorio-maria-flora.jpg';
const lang = getLangFromUrl(Astro.url);
const bookingEmbedLang = lang === 'es' ? 'es' : 'en';
const bookingEmbedUrl = `https://hosthelperai.com/book/casa-maria-flora?lang=${bookingEmbedLang}`;
const translatePath = useTranslatedPath(lang);
const copy = getCmfCopy(lang);
const contactCards = copy.hero.contactCards;
const features = copy.featuresSection.quickFacts;
const amenities = copy.amenitiesSection.items;

const gallery = [
  { src: imgBedroom, alt: 'Bedroom at Casa Maria Flora', cls: 'md:col-span-7 md:row-span-3' },
  { src: imgKitchen, alt: 'Kitchen', cls: 'md:col-span-5 md:row-span-2' },
  { src: imgLiving, alt: 'Living area', cls: 'md:col-span-5 md:row-span-1' },
  { src: imgDining, alt: 'Dining area', cls: 'md:col-span-4 md:row-span-2' },
  { src: imgTerrace, alt: 'Terrace', cls: 'md:col-span-8 md:row-span-2' },
];

const testimonials = copy.testimonialsSection.items;
const faqs = copy.faqSection.items;
---

<Base
  title={copy.meta.title}
  description={copy.meta.description}
>
  <Header />

  <main>
    <section class="pt-[88px] md:pt-[96px] pb-10 px-2 sm:px-3 md:px-4 lg:px-6 bg-background">
      <div class="max-w-[1560px] mx-auto">
        <div class="relative rounded-none md:rounded-[6px] bg-white">
          <div class="relative overflow-hidden md:rounded-[6px]">
            <img src={heroImage} alt="Casa Maria Flora hero" class="w-full h-[480px] md:h-[620px] lg:h-[700px] object-cover" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/15"></div>

            <div class="absolute inset-x-0 top-6 md:top-10 px-3 sm:px-4 md:px-8">
              <FadeIn>
                <div class="mx-auto max-w-[760px] rounded-2xl border border-white/20 bg-[#f4e9dd]/18 backdrop-blur-[2px] px-4 sm:px-5 md:px-8 py-5 md:py-6 text-center text-primary shadow-[0_20px_60px_-35px_rgba(0,0,0,0.22)]">
                  <p class="text-[11px] md:text-xs uppercase tracking-[0.22em] text-[#c96d33]">
                    {copy.hero.location}
                  </p>
                  <p class="mt-2 text-xl md:text-4xl lg:text-5xl font-light leading-tight [text-shadow:0_1px_0_rgba(255,255,255,0.25)]">
                    {copy.hero.title}
                  </p>
                  <h1 class="mt-2 text-[#c96d33] font-sans font-semibold uppercase tracking-[0.05em] !text-3xl md:!text-5xl lg:!text-6xl">
                    Casa Maria Flora
                  </h1>
                </div>
              </FadeIn>
            </div>
          </div>

          <div class="mt-4 px-3 sm:px-4 md:mt-0 md:px-0 md:absolute md:left-1/2 md:-translate-x-1/2 md:bottom-5 lg:bottom-8 w-full md:w-[74%] max-w-[900px]">
            <FadeIn delay={120}>
              <div class="rounded-2xl bg-[#f8f5ef] border border-primary/10 shadow-[0_25px_70px_-40px_rgba(44,42,38,0.45)] px-3 sm:px-4 md:px-6 py-4 md:py-[18px]">
                <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_auto] gap-4 md:gap-0 items-stretch">
                  {contactCards.map((item, idx) => (
                    <div class:list={[
                      'px-1.5 sm:px-2 md:px-5 py-1.5',
                      idx < 2 ? 'md:border-r md:border-primary/10' : '',
                    ]}>
                      <p class="text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-[#9a5a2f] mb-1.5">{item.label}</p>
                      {item.href ? (
                        <a href={item.href} class="block text-primary text-sm md:text-base underline decoration-primary/30 underline-offset-4">
                          {item.value}
                        </a>
                      ) : (
                        <p class="text-primary text-sm md:text-base">{item.value}</p>
                      )}
                      {item.lines.map((line) => (
                        <p class="text-primary/80 text-sm md:text-base">{line}</p>
                      ))}
                    </div>
                  ))}

                  <div class="md:pl-6 flex items-center">
                    <a
                      href={translatePath('/#booking-widget')}
                      class="w-full md:w-auto inline-flex items-center justify-center rounded-xl px-6 md:px-7 py-3 bg-[#d57a3a] text-white text-xs md:text-sm uppercase tracking-[0.14em] hover:bg-[#bf692f] transition-colors"
                    >
                      {copy.hero.cta}
                    </a>
                  </div>
                </div>
              </div>
            </FadeIn>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="scroll-mt-28 pt-24 md:pt-34 pb-20 md:pb-28 px-4 sm:px-6 lg:px-8 bg-background">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-16 items-start">
        <FadeIn>
          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">{copy.featuresSection.eyebrow}</p>
            <h2 class="font-display mb-5">{copy.featuresSection.title}</h2>
            <div class="space-y-4 text-muted leading-relaxed">
              {copy.featuresSection.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
            <div class="mt-6 rounded-xl overflow-hidden aspect-[4/5] sm:aspect-[16/10] border border-primary/10 bg-white">
              <img src={imgDormitorio} alt="Bedroom at Casa Maria Flora" class="w-full h-full object-cover object-center" loading="lazy" />
            </div>
          </div>
        </FadeIn>

        <FadeIn delay={120}>
          <div class="rounded-2xl border border-primary/10 bg-white p-4 sm:p-5 md:p-8">
            <div class="mb-6 rounded-xl overflow-hidden aspect-[16/10]">
              <img src={imgBeach} alt="Marbella beach near Ojen" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <p class="text-xs uppercase tracking-[0.24em] text-[#c96d33] mb-4">{copy.featuresSection.quickFactsLabel}</p>
            <ul class="space-y-3">
              {features.map((item) => (
                <li class="flex gap-3 text-sm md:text-base leading-relaxed text-primary">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#d57a3a] shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </FadeIn>
      </div>
    </section>

    <section id="reserva-directa" class="py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-white scroll-mt-24 md:scroll-mt-32">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
        <FadeIn>
          <article class="rounded-2xl border border-primary/10 bg-[#fbf8f2] p-5 sm:p-6 md:p-9 h-full flex flex-col">
            <p class="text-xs uppercase tracking-[0.25em] text-[#c96d33] mb-4">{copy.ojenCard.eyebrow}</p>
            <h3 class="text-2xl mb-4">{copy.ojenCard.title}</h3>
            <div class="space-y-4 text-muted leading-relaxed flex-grow">
              <p>{copy.ojenCard.intro}</p>
              <h4 class="text-base font-semibold text-primary pt-1">{copy.ojenCard.restaurantsTitle}</h4>
              <p>{copy.ojenCard.restaurantsBody}</p>
              <h4 class="text-base font-semibold text-primary pt-1">{copy.ojenCard.hikesTitle}</h4>
              <p>{copy.ojenCard.hikesBody}</p>
              <ul class="list-disc pl-5 space-y-1 text-sm">
                {copy.ojenCard.hikes.map((hike) => (
                  <li>{hike}</li>
                ))}
              </ul>
            </div>
            <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div class="rounded-xl overflow-hidden aspect-[4/3]">
                <img src={imgOjen} alt="Ojen village view" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="rounded-xl overflow-hidden aspect-[4/3]">
                <img src={imgPlaza} alt="Ojen plaza" class="w-full h-full object-cover" loading="lazy" />
              </div>
            </div>
          </article>
        </FadeIn>

        <FadeIn delay={100}>
          <article id="booking-widget" class="rounded-2xl border border-primary/10 bg-background p-3 sm:p-6 md:p-9 h-full flex flex-col scroll-mt-24 md:scroll-mt-32">
            <p class="text-xs uppercase tracking-[0.25em] text-[#c96d33] mb-1">{copy.directBooking.eyebrow}</p>
            <h3 class="text-2xl mb-4">{copy.directBooking.title}</h3>

            <!-- iframe wrapper — becomes fullscreen target -->
            <div
              id="booking-iframe-wrapper"
              class="flex-grow -mx-3 sm:mx-0 rounded-none sm:rounded-2xl border-y border-primary/10 sm:border sm:border-primary/10 bg-white shadow-none sm:shadow-[0_4px_24px_rgba(0,0,0,0.08)] overflow-hidden relative"
              role="region"
              aria-label={lang === 'es' ? 'Widget de reserva' : 'Booking widget'}
            >
              <iframe
                id="booking-iframe"
                src={bookingEmbedUrl}
                width="100%"
                height="900"
                class="block w-full"
                style="border: none; height: 900px; display: block;"
                loading="lazy"
                title={copy.directBooking.iframeTitle}
              ></iframe>
            </div>
          </article>
        </FadeIn>

      </div>
    </section>

    <section id="booking" class="scroll-mt-28 py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-background">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <div class="rounded-3xl border border-primary/10 bg-white p-5 sm:p-7 md:p-10 lg:p-12">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 items-center">

              <!-- Left: award text -->
              <div>
                <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">
                  {lang === 'es' ? 'Reconocimiento' : 'Recognition'}
                </p>
                <h2 class="font-display mb-5">
                  {lang === 'es'
                    ? 'Premio Traveller Review Awards 2026'
                    : 'Traveller Review Awards 2026'}
                </h2>
                <p class="mt-2 text-muted leading-relaxed text-lg/relaxed max-w-2xl">
                  {lang === 'es'
                    ? 'Casa Maria Flora ha sido galardonada con el Premio Traveller Review Awards 2026 de Booking.com, obteniendo una puntuación de 8,4 sobre 10 gracias a las valoraciones de nuestros huéspedes.'
                    : 'Casa Maria Flora has been awarded the Booking.com Traveller Review Award 2026, achieving a score of 8.4 out of 10 based on our guests\' reviews.'}
                </p>

                <!-- Score badge row -->
                <div class="mt-8 flex flex-wrap items-center gap-6">
                  <div class="flex items-center gap-3 rounded-2xl bg-[#003580] px-6 py-4">
                    <span class="text-white text-4xl font-bold tracking-tight">8,4</span>
                    <div class="text-white/80 text-xs leading-snug">
                      <span class="block font-semibold text-sm">Booking.com</span>
                      <span class="block">{lang === 'es' ? 'sobre 10' : 'out of 10'}</span>
                    </div>
                  </div>
                  <div class="text-muted text-sm leading-relaxed max-w-xs">
                    {lang === 'es'
                      ? 'Basado en las reseñas verificadas de viajeros reales en Booking.com.'
                      : 'Based on verified reviews from real travellers on Booking.com.'}
                  </div>
                </div>

                <div class="mt-8">
                  <a
                    href="https://www.booking.com/hotel/es/casa-maria-flora.es.html"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-7 py-4 bg-[#003580] text-white text-sm uppercase tracking-[0.16em] hover:bg-[#00276e] transition-colors rounded-xl"
                  >
                    {lang === 'es' ? 'Ver en Booking.com' : 'View on Booking.com'}
                  </a>
                </div>
              </div>

              <!-- Right: touch carousel on mobile / side-by-side on desktop -->
              <!-- Mobile: wrapper clips and scroll-snaps; Desktop: plain flex row -->
              <div class="hidden lg:flex lg:flex-row lg:gap-6 lg:items-stretch">
                <!-- Desktop card 1 -->
                <div class="w-48 h-[340px] overflow-hidden rounded-2xl shadow-[0_20px_60px_-20px_rgba(0,53,128,0.35)]">
                  <img src="/Instagram-Stories-Generic_TRA-2026.png" alt="We're proud to be a Traveller Review Award 2026 winner – Booking.com" class="w-full h-full object-contain bg-[#003580]" loading="lazy" />
                </div>
                <!-- Desktop card 2 -->
                <div class="w-48 h-[340px] overflow-hidden rounded-2xl shadow-[0_20px_60px_-20px_rgba(0,53,128,0.35)]">
                  <img src="/Social-Media_TRA-2026.png" alt="Booking.com Traveller Review Award 2026 – 8.4 out of 10" class="w-full h-full object-contain bg-[#003580]" loading="lazy" />
                </div>
              </div>

              <!-- Mobile carousel (hidden on lg+) -->
              <div class="lg:hidden flex flex-col">
                <div
                  id="awards-carousel"
                  class="flex flex-row overflow-x-auto overscroll-x-contain snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
                  role="region"
                  aria-label={lang === 'es' ? 'Galeria de premios deslizable' : 'Swipeable awards gallery'}
                >
                  <!-- Slide 1 -->
                  <div class="snap-center shrink-0 w-full h-[340px] overflow-hidden rounded-2xl shadow-[0_20px_60px_-20px_rgba(0,53,128,0.35)]">
                    <img
                      src="/Instagram-Stories-Generic_TRA-2026.png"
                      alt="We're proud to be a Traveller Review Award 2026 winner – Booking.com"
                      class="w-full h-full object-contain bg-[#003580]"
                      loading="lazy"
                    />
                  </div>
                  <!-- Slide 2 -->
                  <div class="snap-center shrink-0 w-full h-[340px] overflow-hidden rounded-2xl shadow-[0_20px_60px_-20px_rgba(0,53,128,0.35)]">
                    <img
                      src="/Social-Media_TRA-2026.png"
                      alt="Booking.com Traveller Review Award 2026 – 8.4 out of 10"
                      class="w-full h-full object-contain bg-[#003580]"
                      loading="lazy"
                    />
                  </div>
                </div>
                <!-- Dot indicators -->
                <div class="flex justify-center gap-2 mt-3" aria-hidden="true">
                  <button class="awards-dot w-2.5 h-2.5 rounded-full bg-[#003580] transition-opacity" style="opacity:1" data-index="0" aria-label="Card 1"></button>
                  <button class="awards-dot w-2.5 h-2.5 rounded-full bg-[#003580] transition-opacity" style="opacity:0.3" data-index="1" aria-label="Card 2"></button>
                </div>
              </div>

              <script>
                const carousel = document.getElementById('awards-carousel');
                const dots = document.querySelectorAll('.awards-dot');
                if (carousel && dots.length) {
                  carousel.addEventListener('scroll', () => {
                    const idx = Math.round(carousel.scrollLeft / carousel.offsetWidth);
                    dots.forEach((d, i) => {
                      (d as HTMLElement).style.opacity = i === idx ? '1' : '0.3';
                    });
                  }, { passive: true });
                  dots.forEach((dot) => {
                    dot.addEventListener('click', () => {
                      const i = Number((dot as HTMLElement).dataset.index);
                      carousel.scrollTo({ left: i * carousel.offsetWidth, behavior: 'smooth' });
                    });
                  });
                }
              </script>

            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <div class="mb-10">
            <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">{copy.amenitiesSection.eyebrow}</p>
            <h2 class="font-display">{copy.amenitiesSection.title}</h2>
          </div>
        </FadeIn>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
          {amenities.map((item, idx) => (
            <FadeIn delay={idx * 40}>
              <article class="h-full rounded-2xl border border-primary/10 bg-background px-4 py-4 sm:px-5 sm:py-5 md:px-6 md:py-6">
                <div class="flex items-start gap-4">
                  <div class="shrink-0 w-12 h-12 rounded-xl bg-white border border-primary/10 grid place-items-center">
                    <AmenityIcon type={item.iconType} />
                  </div>
                  <div class="min-w-0">
                    <h3 class="text-base font-semibold text-primary leading-tight">{item.title}</h3>
                    <p class="mt-2 text-sm text-muted leading-relaxed">{item.description}</p>
                  </div>
                </div>
              </article>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-background">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
        <FadeIn>
          <article class="rounded-2xl border border-primary/10 bg-white p-5 sm:p-6 md:p-9 h-full">
            <p class="text-xs uppercase tracking-[0.25em] text-[#c96d33] mb-4">{copy.policies.longStayTitle}</p>
            <p class="text-muted leading-relaxed">{copy.policies.longStayBody}</p>
          </article>
        </FadeIn>
        <FadeIn delay={100}>
          <article class="rounded-2xl border border-primary/10 bg-white p-5 sm:p-6 md:p-9 h-full">
            <p class="text-xs uppercase tracking-[0.25em] text-[#c96d33] mb-4">{copy.policies.cancellationTitle}</p>
            <div class="space-y-2 text-muted">
              {copy.policies.cancellationItems.map((item) => (
                <p>{item}</p>
              ))}
            </div>
          </article>
        </FadeIn>
      </div>
    </section>

    <section id="gallery" class="scroll-mt-28 py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <div class="mb-12">
            <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">{copy.gallerySection.eyebrow}</p>
            <h2 class="font-display">{copy.gallerySection.title}</h2>
          </div>
        </FadeIn>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 auto-rows-[220px] md:auto-rows-[180px]">
          {gallery.map((item, idx) => (
            <FadeIn delay={idx * 80} class={`${item.cls} overflow-hidden rounded-2xl`}>
              <img src={item.src} alt={item.alt} class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" loading="lazy" />
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-[#ddb8a7] border-t border-[#9b5d3d]">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <div class="mb-10 md:mb-14">
            <h2 class="font-sans font-semibold text-white text-4xl md:text-6xl leading-[0.95] max-w-xl">
              {copy.testimonialsSection.title}
            </h2>
          </div>
        </FadeIn>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 items-start">
          {testimonials.map((item, idx) => (
            <FadeIn delay={idx * 100}>
              <blockquote class="rounded-2xl bg-white p-5 sm:p-8 md:p-10 h-full shadow-[0_16px_40px_-28px_rgba(63,22,0,0.35)]">
                <div class="text-[#e7c36f] text-3xl tracking-[0.08em] leading-none mb-8" aria-hidden="true">
                  ★★★★★
                </div>
                <p class="text-[#d3a08e] text-2xl md:text-[2.05rem] leading-[1.35] font-semibold">
                  “{item.quote}”
                </p>
                <footer class="mt-12">
                  <p class="text-primary text-2xl font-semibold">{item.author}</p>
                  <p class="mt-3 text-muted text-lg">{item.visit}</p>
                </footer>
              </blockquote>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="scroll-mt-28 py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <div class="mb-10">
            <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">{copy.faqSection.eyebrow}</p>
            <h2 class="font-display">{copy.faqSection.title}</h2>
          </div>
        </FadeIn>

        <div class="space-y-4">
          {faqs.map((faq, idx) => (
            <FadeIn delay={idx * 60}>
              <details class="group rounded-2xl border border-primary/10 bg-background p-4 sm:p-5 md:p-6">
                <summary class="list-none cursor-pointer flex items-start justify-between gap-4">
                  <span class="text-base md:text-lg font-medium">{faq.q}</span>
                  <span class="mt-1 text-[#c96d33] transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-4 text-sm md:text-base text-muted leading-relaxed pr-6">{faq.a}</p>
              </details>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section id="about-us" class="scroll-mt-28 py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-background">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 items-center">
        <FadeIn>
          <div class="rounded-2xl overflow-hidden aspect-[4/5]">
            <img src={imgSisters} alt="Maria and Flora" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </FadeIn>

        <FadeIn delay={100}>
          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-[#c96d33] mb-4">{copy.aboutSection.eyebrow}</p>
            <h2 class="font-display mb-5">{copy.aboutSection.title}</h2>
