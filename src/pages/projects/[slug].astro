---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FadeIn from '../../components/FadeIn.astro';
import ParallaxImage from '../../components/ParallaxImage.astro';

import project1 from '../../assets/images/project-1.svg';
import project2 from '../../assets/images/project-2.svg';
import project3 from '../../assets/images/project-3.svg';

// Static paths for SSG
export function getStaticPaths() {
  return [
    { params: { slug: 'serene-escape' } },
    { params: { slug: 'urban-sanctuary' } },
    { params: { slug: 'coastal-retreat' } },
  ];
}

const { slug } = Astro.params;

// Project data (in a real app, this would come from a CMS or content collection)
const projectsData: Record<string, {
  title: string;
  category: string;
  location: string;
  year: string;
  description: string;
  images: typeof project1[];
}> = {
  'serene-escape': {
    title: 'Serene Escape',
    category: 'Residential',
    location: 'Amsterdam, Netherlands',
    year: '2024',
    description: 'A tranquil residential project that combines modern minimalism with warm, natural materials. Every detail was carefully considered to create a space that feels both sophisticated and deeply comfortable.',
    images: [project1, project2, project3],
  },
  'urban-sanctuary': {
    title: 'Urban Sanctuary',
    category: 'Residential',
    location: 'Rotterdam, Netherlands',
    year: '2024',
    description: 'An urban oasis designed to provide respite from the bustling city. Clean lines, muted tones, and thoughtful spatial planning create a sense of calm and clarity.',
    images: [project2, project3, project1],
  },
  'coastal-retreat': {
    title: 'Coastal Retreat',
    category: 'Residential',
    location: 'The Hague, Netherlands',
    year: '2023',
    description: 'Inspired by the nearby coastline, this project embraces light, space, and natural textures. The result is a home that feels connected to its environment while maintaining a timeless elegance.',
    images: [project3, project1, project2],
  },
};

const project = projectsData[slug as string];

if (!project) {
  return Astro.redirect('/projects');
}
---

<Base 
  title={`${project.title} — Elske Lena`}
  description={project.description}
>
  <Header />
  
  <main class="pt-24">
    <!-- Hero -->
    <section class="py-20 px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <nav class="mb-8">
            <a href="/projects" class="text-sm text-muted hover:text-foreground transition-colors">
              ← Back to projects
            </a>
          </nav>
        </FadeIn>
        
        <FadeIn delay={100}>
          <h1 class="uppercase tracking-wide">{project.title}</h1>
        </FadeIn>
        
        <FadeIn delay={200}>
          <div class="mt-8 flex flex-wrap gap-8 text-sm text-muted">
            <div>
              <span class="block text-xs uppercase tracking-widest mb-1">Category</span>
              <span>{project.category}</span>
            </div>
            <div>
              <span class="block text-xs uppercase tracking-widest mb-1">Location</span>
              <span>{project.location}</span>
            </div>
            <div>
              <span class="block text-xs uppercase tracking-widest mb-1">Year</span>
              <span>{project.year}</span>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>
    
    <!-- Main Image -->
    <section class="px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <FadeIn>
          <div class="aspect-[16/9] overflow-hidden">
            <ParallaxImage 
              src={project.images[0]} 
              alt={project.title}
              class="h-full"
              speed={0.15}
            />
          </div>
        </FadeIn>
      </div>
    </section>
    
    <!-- Description -->
    <section class="py-20 px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-2xl">
          <FadeIn>
            <p class="text-lg leading-relaxed text-muted">
              {project.description}
            </p>
          </FadeIn>
        </div>
      </div>
    </section>
    
    <!-- Gallery -->
    <section class="py-8 px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {project.images.slice(1).map((image, index) => (
            <FadeIn delay={index * 100}>
              <div class="aspect-[4/3] overflow-hidden">
                <img 
                  src={image.src}
                  alt={`${project.title} - Image ${index + 2}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Navigation -->
    <section class="py-20 px-6 lg:px-8 border-t border-primary/10">
      <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-center">
          <a 
            href="/projects" 
            class="text-sm uppercase tracking-widest hover:opacity-70 transition-opacity"
          >
            ← All projects
          </a>
          <a 
            href="/contact" 
            class="text-sm uppercase tracking-widest hover:opacity-70 transition-opacity"
          >
            Start a project →
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Base>
